# Terraform state and runtime
*.tfstate
*.tfstate.*
*.tfvars
# Track per-environment knob files (vrf_template_name, mso_domain, mso_platform).
# These contain NO credentials — credentials live exclusively in terraform.tfvars
# (auto-loaded, still gitignored above) and CI variables. The lab/prod selectors
# are committed because CI must read them via `-var-file=${TF_VARS_FILE}` and the
# default selection (lab.tfvars) needs to exist on a fresh clone. See the file
# headers and `.gitlab-ci.yml` for the rationale.
!lab.tfvars
!prod.tfvars
.terraform/
.terraform.lock.hcl
*.tfplan
crash.log

# Disabled/offline/backup Terraform configs
*.disabled
*.offline
*.backup

# Local-only Terraform overrides — used to swap the http backend for a local
# backend during interactive lab work on a laptop. Must never be committed:
# CI must keep using the http backend driven by TF_HTTP_* env vars.
*_override.tf
*_override.tf.json

# Directories not needed in repo
test-ndo/
tf-modules/

# Python scripts and artifacts
*.py
__pycache__/
*.py[cod]
venv/
env/

# Data and binary files
*.json
*.tar.gz
*.zip
*.xlsx
*.csv

# Logs
*.log
*.out

# Credentials
*password*
*secret*
*token*
*credential*
vault.yml
vault_pass.txt
backend.hcl

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~