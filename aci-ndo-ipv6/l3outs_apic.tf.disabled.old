# ============================================================================
# APIC-SPECIFIC L3OUT CONFIGURATION - RCC-E
# ============================================================================
# This file configures the site-level L3Out details directly on APIC
# using the ACI Terraform provider.
#
# L3Out Name: L3Out-RCC-E (same name at both sites)
#
# Prerequisites:
#   - L3Outs must be deployed from NDO first (via l3outs_ndo.tf)
#   - APIC credentials configured
#   - ACI provider added to main.tf required_providers block
#
# Placeholder values (modify as needed):
#   - VLAN: 3500
#   - Site G IPs: fd00:rcc:1::1/64, fd00:rcc:1::2/64
#   - Site K IPs: fd00:rcc:2::1/64, fd00:rcc:2::2/64
#   - Nodes: 101, 102 (border leaves)
#   - Ports: PC_DC_FTD_A, PC_DC_FTD_B (same as IPv4 L3Out)
#
# ============================================================================
# DEPLOYMENT ORDER:
#   1. First: Deploy NDO resources (terraform apply l3outs_ndo.tf)
#   2. Wait for NDO to push L3Outs to APIC
#   3. Then: Uncomment the resources below and run terraform apply again
# ============================================================================

# ============================================================================
# VARIABLES
# ============================================================================

variable "apic_g_url" {
  description = "APIC URL for Site G (Grafenwoehr)"
  type        = string
  default     = "https://10.51.32.20"  # Change this
}

variable "apic_k_url" {
  description = "APIC URL for Site K (Kaiserslautern)"
  type        = string
  default     = "https://10.51.33.20"  # Change this
}

variable "apic_username" {
  description = "APIC username"
  type        = string
  default     = "svc.rcc.nmd.dc"
}

variable "apic_password" {
  description = "APIC password"
  type        = string
  sensitive   = true
  default     = ""  # Set in terraform.tfvars
}

variable "tenant_name" {
  description = "Tenant name"
  type        = string
  default     = "EUR"
}

variable "l3out_vlan" {
  description = "VLAN for L3Out SVI"
  type        = number
  default     = 3500  # Change this
}

# ============================================================================
# OSPF VARIABLES
# ============================================================================

variable "ospf_area_id" {
  description = "OSPF Area ID"
  type        = string
  default     = "0.0.0.0"  # Change this - Area ID for RCC-E
}

variable "ospf_area_type" {
  description = "OSPF Area Type (regular, stub, nssa)"
  type        = string
  default     = "regular"
}

variable "ospf_area_cost" {
  description = "OSPF Area Cost"
  type        = number
  default     = 1
}

variable "ospf_hello_interval" {
  description = "OSPF Hello Interval in seconds"
  type        = number
  default     = 10
}

variable "ospf_dead_interval" {
  description = "OSPF Dead Interval in seconds"
  type        = number
  default     = 40
}

variable "ospf_network_type" {
  description = "OSPF Network Type (bcast, p2p)"
  type        = string
  default     = "bcast"  # broadcast for SVI
}

# ============================================================================
# PROVIDERS - Separate provider for each APIC
# ============================================================================

provider "aci" {
  alias    = "apic_g"
  username = var.apic_username
  password = var.apic_password
  url      = var.apic_g_url
  insecure = true
}

provider "aci" {
  alias    = "apic_k"
  username = var.apic_username
  password = var.apic_password
  url      = var.apic_k_url
  insecure = true
}

# ============================================================================
# WARNING: UNCOMMENT THE RESOURCES BELOW AFTER NDO L3OUTS ARE DEPLOYED
# ============================================================================
# To uncomment: Remove the /* at the start and */ at the end
# ============================================================================

#/*
# ============================================================================
# SITE G (Site1 / Grafenwoehr) - L3OUT CONFIGURATION
# ============================================================================

# Data source to reference existing L3Out (deployed from NDO)
data "aci_l3_outside" "l3out_rcc_e_g" {
  provider   = aci.apic_g
  tenant_dn  = "uni/tn-${var.tenant_name}"
  name       = "L3Out-RCC-E-G"
}

# OSPF External Policy for Site G L3Out
resource "aci_l3out_ospf_external_policy" "l3out_rcc_e_g_ospf" {
  provider      = aci.apic_g
  l3_outside_dn = data.aci_l3_outside.l3out_rcc_e_g.id
  area_cost     = var.ospf_area_cost
  area_ctrl     = ["redistribute", "summary"]
  area_id       = var.ospf_area_id
  area_type     = var.ospf_area_type
}

# Logical Node Profile - Site G
resource "aci_logical_node_profile" "l3out_rcc_e_g_node_profile" {
  provider   = aci.apic_g
  l3_outside_dn = data.aci_l3_outside.l3out_rcc_e_g.id
  name          = "NodeProfile-RCC-E"
  description   = "Node profile for RCC-E L3Out - Site G"
}

# Node 101 - Site G
resource "aci_logical_node_to_fabric_node" "l3out_rcc_e_g_node_101" {
  provider                  = aci.apic_g
  logical_node_profile_dn   = aci_logical_node_profile.l3out_rcc_e_g_node_profile.id
  tdn                       = "topology/pod-1/node-101"
  rtr_id                    = "10.51.59.251"  # Change this - Router ID for node 101
  rtr_id_loop_back          = "no"
}

# Node 102 - Site G
resource "aci_logical_node_to_fabric_node" "l3out_rcc_e_g_node_102" {
  provider                  = aci.apic_g
  logical_node_profile_dn   = aci_logical_node_profile.l3out_rcc_e_g_node_profile.id
  tdn                       = "topology/pod-1/node-102"
  rtr_id                    = "10.51.59.252"  # Change this - Router ID for node 102
  rtr_id_loop_back          = "no"
}

# Logical Interface Profile - Site G
resource "aci_logical_interface_profile" "l3out_rcc_e_g_int_profile" {
  provider                  = aci.apic_g
  logical_node_profile_dn   = aci_logical_node_profile.l3out_rcc_e_g_node_profile.id
  name                      = "IntProfile-RCC-E"
  description               = "Interface profile for RCC-E L3Out - Site G"
}

# OSPF Interface Profile - Site G
resource "aci_l3out_ospf_interface_profile" "l3out_rcc_e_g_ospf_int" {
  provider                      = aci.apic_g
  logical_interface_profile_dn  = aci_logical_interface_profile.l3out_rcc_e_g_int_profile.id
  auth_key                      = "TempKey123!"  # CHANGE THIS - temporary OSPFv3 auth key
  auth_key_id                   = "1"
  auth_type                     = "md5"
  relation_ospf_rs_if_pol       = "uni/tn-${var.tenant_name}/ospfIfPol-OSPF-IntPol-L3Out"
}

# SVI Path Attachment - PC_DC_FTD_A - Site G
resource "aci_l3out_path_attachment" "l3out_rcc_e_g_ftd_a" {
  provider                      = aci.apic_g
  logical_interface_profile_dn  = aci_logical_interface_profile.l3out_rcc_e_g_int_profile.id
  target_dn                     = "topology/pod-1/protpaths-101-102/pathep-[PC_DC_FTD_A]"
  if_inst_t                     = "ext-svi"
  addr                          = "2609:efff:b33b:1::1/64"  # Change this - Primary IPv6 address
  encap                         = "vlan-${var.l3out_vlan}"
  encap_scope                   = "local"
  mode                          = "regular"
  mtu                           = "inherit"
}

# SVI Path Attachment - PC_DC_FTD_B - Site G
resource "aci_l3out_path_attachment" "l3out_rcc_e_g_ftd_b" {
  provider                      = aci.apic_g
  logical_interface_profile_dn  = aci_logical_interface_profile.l3out_rcc_e_g_int_profile.id
  target_dn                     = "topology/pod-1/protpaths-101-102/pathep-[PC_DC_FTD_B]"
  if_inst_t                     = "ext-svi"
  addr                          = "2609:efff:b33b:1::2/64"  # Change this - Primary IPv6 address
  encap                         = "vlan-${var.l3out_vlan}"
  encap_scope                   = "local"
  mode                          = "regular"
  mtu                           = "inherit"
}

# ============================================================================
# SITE G - L3OUT PROPERTIES (Route Control, L3 Domain)
# ============================================================================

# Route Control Enforcement = Import + Export (export is always enforced in ACI)
resource "aci_rest_managed" "l3out_rcc_e_g_enforce_rtctrl" {
  provider   = aci.apic_g
  dn         = "uni/tn-${var.tenant_name}/out-L3Out-RCC-E-G"
  class_name = "l3extOut"
  content = {
    enforceRtctrl = "import,export"
  }
}

# L3 Domain Association
resource "aci_rest_managed" "l3out_rcc_e_g_l3dom" {
  provider   = aci.apic_g
  dn         = "uni/tn-${var.tenant_name}/out-L3Out-RCC-E-G/rsl3DomAtt"
  class_name = "l3extRsL3DomAtt"
  content = {
    tDn = "uni/l3dom-L3_Dom_Ext_Routes"
  }
}

# ============================================================================
# SITE G - DEFAULT-IMPORT ROUTE MAP (only import IPv6 default route)
# ============================================================================

# Match Rule: Allow_:: (tenant-level, matches ::/0)
resource "aci_rest_managed" "match_rule_allow_ipv6_default_g" {
  provider   = aci.apic_g
  dn         = "uni/tn-${var.tenant_name}/subj-Allow_::"
  class_name = "rtctrlSubjP"
  content = {
    name = "Allow_::"
  }
}

resource "aci_rest_managed" "match_rule_allow_ipv6_default_dest_g" {
  provider   = aci.apic_g
  dn         = "${aci_rest_managed.match_rule_allow_ipv6_default_g.id}/dest-[::/0]"
  class_name = "rtctrlMatchRtDest"
  content = {
    ip        = "::/0"
    aggregate = "no"
  }
  depends_on = [aci_rest_managed.match_rule_allow_ipv6_default_g]
}

# Route Control Profile: default-import (under L3Out)
resource "aci_rest_managed" "l3out_rcc_e_g_rtctrl_profile" {
  provider   = aci.apic_g
  dn         = "uni/tn-${var.tenant_name}/out-L3Out-RCC-E-G/prof-default-import"
  class_name = "rtctrlProfile"
  content = {
    name = "default-import"
  }
  depends_on = [aci_rest_managed.l3out_rcc_e_g_enforce_rtctrl]
}

# Route Control Context: Allow_:: (under default-import profile)
resource "aci_rest_managed" "l3out_rcc_e_g_rtctrl_ctx" {
  provider   = aci.apic_g
  dn         = "${aci_rest_managed.l3out_rcc_e_g_rtctrl_profile.id}/ctx-Allow_::"
  class_name = "rtctrlCtxP"
  content = {
    name   = "Allow_::"
    action = "permit"
    order  = "0"
  }
  depends_on = [aci_rest_managed.l3out_rcc_e_g_rtctrl_profile]
}

# Associate context with match rule
resource "aci_rest_managed" "l3out_rcc_e_g_rtctrl_scope" {
  provider   = aci.apic_g
  dn         = "${aci_rest_managed.l3out_rcc_e_g_rtctrl_ctx.id}/rsctxPToSubjP-Allow_::"
  class_name = "rtctrlRsCtxPToSubjP"
  content = {
    tnRtctrlSubjPName = "Allow_::"
  }
  depends_on = [aci_rest_managed.l3out_rcc_e_g_rtctrl_ctx, aci_rest_managed.match_rule_allow_ipv6_default_g]
}

# ============================================================================
# SITE K (Site2 / Kaiserslautern) - L3OUT CONFIGURATION
# ============================================================================

# Data source to reference existing L3Out (deployed from NDO)
data "aci_l3_outside" "l3out_rcc_e_k" {
  provider   = aci.apic_k
  tenant_dn  = "uni/tn-${var.tenant_name}"
  name       = "L3Out-RCC-E-K"
}

# OSPF External Policy for Site K L3Out
resource "aci_l3out_ospf_external_policy" "l3out_rcc_e_k_ospf" {
  provider      = aci.apic_k
  l3_outside_dn = data.aci_l3_outside.l3out_rcc_e_k.id
