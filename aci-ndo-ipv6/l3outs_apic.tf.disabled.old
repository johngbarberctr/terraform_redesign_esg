  }
}

# ============================================================================
# SITE K - DEFAULT-IMPORT ROUTE MAP (only import IPv6 default route)
# ============================================================================

# Match Rule: Allow_:: (tenant-level, matches ::/0)
resource "aci_rest_managed" "match_rule_allow_ipv6_default_k" {
  provider   = aci.apic_k
