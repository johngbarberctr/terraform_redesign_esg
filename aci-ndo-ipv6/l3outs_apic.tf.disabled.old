output "l3out_rcc_e_k_int_profile_dn" {
  description = "Site K Interface Profile DN"
  value       = aci_logical_interface_profile.l3out_rcc_e_k_int_profile.id
}
#*/

# ============================================================================
# USAGE NOTES
# ============================================================================
#
# DEPLOYMENT STEPS:
# 1. Deploy NDO configuration first:
#    terraform apply -target=module.ndo  (or just the l3outs_ndo.tf resources)
#
# 2. Wait for NDO to push L3Outs to APIC (check in APIC GUI)
#
# 3. Uncomment the APIC resources above (remove /* and */)
#
# 4. Deploy APIC configuration:
#    terraform apply
#
# PLACEHOLDER VALUES TO UPDATE:
# - var.apic_g_url          -> Your Site G APIC URL
# - var.apic_k_url          -> Your Site K APIC URL
# - var.apic_password       -> Set in terraform.tfvars
# - var.l3out_vlan          -> VLAN for SVI (currently 3500)
# - var.ospf_area_id        -> OSPF Area ID
# - Router IDs              -> Unique per node (10.66.x.x placeholders)
# - IPv6 addresses          -> fd00:rcc:x::x/64 placeholders
# - Port channels           -> PC_DC_FTD_A, PC_DC_FTD_B (same as IPv4)
#
# ============================================================================
