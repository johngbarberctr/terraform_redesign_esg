#*/

# ============================================================================
# OUTPUTS
# ============================================================================

# Uncomment these after uncommenting the resources above
#/*
output "l3out_rcc_e_g_node_profile_dn" {
  description = "Site G Node Profile DN"
  value       = aci_logical_node_profile.l3out_rcc_e_g_node_profile.id
}

output "l3out_rcc_e_g_int_profile_dn" {
  description = "Site G Interface Profile DN"
  value       = aci_logical_interface_profile.l3out_rcc_e_g_int_profile.id
