  area_ctrl     = ["redistribute", "summary"]
  area_id       = var.ospf_area_id
  area_type     = var.ospf_area_type
}

# Logical Node Profile - Site K
resource "aci_logical_node_profile" "l3out_rcc_e_k_node_profile" {
  provider      = aci.apic_k
  l3_outside_dn = data.aci_l3_outside.l3out_rcc_e_k.id
  name          = "NodeProfile-RCC-E"
  description   = "Node profile for RCC-E L3Out - Site K"
}

# Node 101 - Site K
resource "aci_logical_node_to_fabric_node" "l3out_rcc_e_k_node_101" {
  provider                  = aci.apic_k
  logical_node_profile_dn   = aci_logical_node_profile.l3out_rcc_e_k_node_profile.id
  tdn                       = "topology/pod-1/node-101"
