  relation_ospf_rs_if_pol       = "uni/tn-${var.tenant_name}/ospfIfPol-OSPF-IntPol-L3Out"
}

# SVI Path Attachment - PC_DC_FTD_A - Site K
resource "aci_l3out_path_attachment" "l3out_rcc_e_k_ftd_a" {
  provider                      = aci.apic_k
  logical_interface_profile_dn  = aci_logical_interface_profile.l3out_rcc_e_k_int_profile.id
  target_dn                     = "topology/pod-1/protpaths-101-102/pathep-[PC_DC_FTD_A]"
  if_inst_t                     = "ext-svi"
  addr                          = "2609:efff:b30e:2::1/64"  # Change this - Primary IPv6 address
  encap                         = "vlan-${var.l3out_vlan}"
  encap_scope                   = "local"
  mode                          = "regular"
  mtu                           = "inherit"
}

# SVI Path Attachment - PC_DC_FTD_B - Site K
resource "aci_l3out_path_attachment" "l3out_rcc_e_k_ftd_b" {
  provider                      = aci.apic_k
  logical_interface_profile_dn  = aci_logical_interface_profile.l3out_rcc_e_k_int_profile.id
  target_dn                     = "topology/pod-1/protpaths-101-102/pathep-[PC_DC_FTD_B]"
  if_inst_t                     = "ext-svi"
