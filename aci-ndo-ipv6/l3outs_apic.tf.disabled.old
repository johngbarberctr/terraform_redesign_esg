}

# ============================================================================
# SITE K - L3OUT PROPERTIES (Route Control, L3 Domain)
# ============================================================================

# Route Control Enforcement = Import + Export (export is always enforced in ACI)
resource "aci_rest_managed" "l3out_rcc_e_k_enforce_rtctrl" {
  provider   = aci.apic_k
