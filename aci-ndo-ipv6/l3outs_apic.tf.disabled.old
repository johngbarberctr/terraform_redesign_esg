  provider                      = aci.apic_k
  logical_interface_profile_dn  = aci_logical_interface_profile.l3out_rcc_e_k_int_profile.id
  auth_key                      = "TempKey123!"  # CHANGE THIS - temporary OSPFv3 auth key
  auth_key_id                   = "1"
