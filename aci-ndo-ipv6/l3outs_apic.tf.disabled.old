  }
}

# L3 Domain Association
resource "aci_rest_managed" "l3out_rcc_e_k_l3dom" {
  provider   = aci.apic_k
  dn         = "uni/tn-${var.tenant_name}/out-L3Out-RCC-E-K/rsl3DomAtt"
