# Per-fabric APIC URLs and usernames for the lab.
# (.example extension so git tracks this without triggering the .tfvars policy;
#  contains no secrets — passwords/keys are injected via TF_VAR_* env vars.)
#
# Sensitive values (apic passwords, mcp keys) are deliberately NOT declared
# in this file. Terraform's variable precedence makes terraform.tfvars beat
# TF_VAR_* environment variables, which would defeat the secret-injection
# pattern. Export them before `make plan` / `make apply`:
#
#   source scripts/set-apic-password.sh                # both fabrics, same pw
#   eval  "$(./scripts/generate-mcp-key.sh kelley)"    # TF_VAR_kelley_mcp_key
#   eval  "$(./scripts/generate-mcp-key.sh deldin)"    # TF_VAR_deldin_mcp_key
#
# vCenter values (hostname_ip / datacenter / username / password / dvs_version)
# are NOT Terraform variables either; they are read directly by
# scripts/render-vmm-yaml.sh from TF_VAR_vcenter_* env vars to produce the
# (gitignored) rendered VMM-domain YAML before `terraform plan`. See
# aci-redesign/README.md sections 4-5.
#
# IP HEADS-UP: lab APIC IPs change periodically. The values below are the
# current (2026-05-04) lab assignment: Kelley=198.18.134.252, Del-Din=.253.
# If `make auth-check` returns HTTP 000 (no response) or a connect timeout,
# the IP is stale -- update both URLs here to match the current lab.
# HTTP 401 means the IP is correct but the password is wrong; use
# `source scripts/set-apic-password.sh` to set it cleanly.

kelley_apic_url      = "https://198.18.134.252"
kelley_apic_username = "admin"

deldin_apic_url      = "https://198.18.134.253"
deldin_apic_username = "admin"

manage_tenants = true
