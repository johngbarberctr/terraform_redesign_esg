# Terraform
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl
*.tfplan
crash.log
terraform_debug.log
# Local-only Terraform overrides used to swap the http backend (CI-driven)
# for a local backend on a developer laptop. See ndo-terraform-ipv6/.gitignore
# for an explanation; the same pattern applies to every sub-project that
# declares `backend "http" {}`.
*_override.tf
*_override.tf.json
# Local-state backups created by the migration helper.
.local-state-backups/

# Python
__pycache__/
*.py[cod]
venv/
env/

# IDE/OS
.DS_Store
.vscode/
.idea/
*.swp
*.code-workspace

# Office lock/temp files (e.g. ~$ACI_Redesign_Strategy.pptx -- created by Word/
# PowerPoint/Excel when a file is open; never want these in git)
~$*
*.tmp
Thumbs.db

# Logs
*.log
nohup.out

# Credentials
*password*
*secret*
# Allow CI tooling whose name intentionally contains "secret".
!.gitlab/ci-secret-scan.sh
vault.yml
vault_pass.txt
.env
# Token files (API tokens, session tokens)
token/

# Generated/binary files
*.json
# Allow checked-in example/template JSON (sanitized -- no real credentials),
# mirrors the *.tfvars / !*.tfvars.example pattern above.
!*.example.json
# Allow the FI-binding manifest committed alongside the schema. This file
# is sanitized by generate_fi_bindings.py (--output-manifest): no creds,
# no VLANs -- just the EPG list and the chosen mode. CI uses it as the
# parity-check reference for schema-vs-bindings drift.
!aci-redesign/scripts/fi_epg_manifest.json
*.tar.gz
*.zip
*.xlsx
*.docx
*.pptx
*.pdf

# Versioned/backup script copies (e.g. generate_ipv6_bindings1.py,
# parse_ndo_backup_v2.py). Canonical versions have no trailing digit.
*[0-9].py

# Disabled or archived source files
*.old

# Design/strategy documents and generated reports not for version control
aci-ndo-ipv6/NDO_TERRAFORM_PRESENTATION.md
docs/ACI_STRATEGY_DECISIONS.md
docs/ACI_STRATEGY_DECISIONS_EXEC_SUMMARY.md
docs/AFRICOM/AFRICOM_Implementation_Plan.md
docs/presentations/RCC-E_IPv6_Infrastructure_Executive_Summary.md
docs/reports/BD_EPG_SETTINGS_COMPARISON_REPORT.md

# Backups directory (large, contains state files and binaries)
backups/

# Ansible vault
vault_pass.txt
vault_plaintext.yml

# Rendered NAC YAML (contains sensitive vCenter credentials substituted into
# templates/vmm-domain.nac.yaml.tftpl by scripts/render-vmm-yaml.sh -- one dir
# per fabric per environment, all gitignored). The wildcard covers both lab
# (-rendered) and production (-prod-rendered) outputs.
aci-apic/data/nac-aci-*-rendered/

# Staging sub-projects (full Terraform trees; tracked separately when ready)
africom-aci-apic/
africom-aci-ndo/

# Utility/exploratory scripts in docs/ that are not part of the deliverable
docs/build_rcc_object_model.py
