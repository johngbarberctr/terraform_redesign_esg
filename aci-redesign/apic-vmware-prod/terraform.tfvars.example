# Production per-fabric APIC connection settings. Copy to terraform.tfvars
# and adjust for your environment. terraform.tfvars is gitignored.
#
# Sensitive values come from TF_VAR_* env vars / GitLab CI masked variables
# / Vault, never from this file:
#
#   export TF_VAR_aedcg_apic_password='<AEDCG production admin password>'
#   export TF_VAR_aedck_apic_password='<AEDCK production admin password>'
#   eval  "$(./scripts/generate-mcp-key.sh aedcg)"  # sets TF_VAR_aedcg_mcp_key
#   eval  "$(./scripts/generate-mcp-key.sh aedck)"  # sets TF_VAR_aedck_mcp_key
#
# vCenter values (read by scripts/render-vmm-yaml.sh, not Terraform):
#   export TF_VAR_vcenter_hostname_ip='VCENTER-IP-OR-FQDN'
#   export TF_VAR_vcenter_datacenter='DATACENTER-NAME'
#   export TF_VAR_vcenter_username='<vCenter service account>'
#   export TF_VAR_vcenter_password='<vCenter service account password>'
#   export TF_VAR_vcenter_dvs_version='unmanaged'
#       # vCenter 7.x/8.x => use "unmanaged" (the netascode/nac-aci validator
#       # only accepts: unmanaged | 5.1 | 5.5 | 6.0 | 6.5 | 6.6).
#
# See aci-redesign/README.md production cutover section.

aedcg_apic_url      = "https://AEDCG-PROD-APIC-URL"
aedcg_apic_username = "admin"

aedck_apic_url      = "https://AEDCK-PROD-APIC-URL"
aedck_apic_username = "admin"
