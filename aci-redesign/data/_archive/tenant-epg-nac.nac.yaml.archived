        - name: BD-D64-PROXY
          vrf: VRF-DMZ

        # ── BD-FWEB-PROXY ───────────────────────────────────────────────────
        # From: BD-V0950 (PVT_DMZ_IN, was EUR-AIP), BD-V1119
        - name: BD-FWEB-PROXY
          vrf: VRF-DMZ
          subnets:
            - ip: 139.139.1.129/26
              public: true
              shared: false
            - ip: 139.139.1.65/26
              public: true
              shared: false
            # PREV-UNMATCHED -- BD-V1119 (no alias, EUR-AIZ, 139.139.x DMZ range)
            - ip: 139.139.251.1/28
              public: true
              shared: false

        # ── BD-RWEB-PROXY (IPv6-only, no IPv4 predecessor) ──────────────────
        - name: BD-RWEB-PROXY
          vrf: VRF-DMZ

