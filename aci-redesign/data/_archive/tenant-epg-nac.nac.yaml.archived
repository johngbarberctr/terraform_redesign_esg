# EUR tenant -- 2-VRF IPv4 redesign matching the 39-BD/EPG IPv6 RCC structure.
#
# Architecture:
#   VRF-EUR   -- all internal IPv4 EPGs (36), vzAny permit-all via Any_VRF-EUR
#   VRF-DMZ   -- DMZ proxy EPGs (3), routing-isolated from internal, vzAny via Any_VRF-DMZ
#   VRF-RCC   -- IPv6 (managed separately in ndo-terraform-nac/136.215.4.96)
#
# Subnet consolidation:
#   All 215 legacy IPv4 BDs are accounted for:
#     - 177 mapped to the 39 functional BDs below (110 subnets total)
#     - 24 decommission candidates (dead/deprecated/test -- no subnets)
#     - 14 mapped but L2-only (no subnets to contribute)
#   Old BD references are noted inline so subnets can be traced back.
#   BDs with no IPv4 predecessor have no subnets and exist as placeholders.
#
# Naming follows production (schema AEDCE / tenant EUR):
#   Contract:    Any_<VRF>           e.g. Any_VRF-EUR, Any_VRF-DMZ
#   Filter:      Any
#   App profile: AppProf-<purpose>   e.g. AppProf-NetCentric, AppProf-DMZ
#   BD/EPG/ESG:  BD-/EPG-/ESG- prefix with descriptive function name
#
# VMM uses dynamic VLAN assignment from vmm-vlan-pool (3501-3967).
---
apic:
  tenants:
    - name: EUR

# ── Filters ────────────────────────────────────────────────────────────────────

      filters:
        - name: Any
          entries:
            - name: Any
              ethertype: unspecified

# ── Contracts ──────────────────────────────────────────────────────────────────

      contracts:
        - name: Any_VRF-EUR
          description: "vzAny permit-all -- VRF-EUR is both consumer and provider"
          scope: context
          subjects:
            - name: Any
              filters:
                - filter: Any

        - name: Any_VRF-DMZ
          description: "vzAny permit-all -- VRF-DMZ is both consumer and provider"
          scope: context
          subjects:
            - name: Any
              filters:
                - filter: Any

# ── VRFs ───────────────────────────────────────────────────────────────────────

      vrfs:
        - name: VRF-EUR
          contracts:
            providers:
              - Any_VRF-EUR
            consumers:
              - Any_VRF-EUR

        - name: VRF-DMZ
          contracts:
            providers:
              - Any_VRF-DMZ
            consumers:
              - Any_VRF-DMZ

# ══════════════════════════════════════════════════════════════════════════════
# Bridge Domains -- Internal (VRF-EUR) -- 36 BDs
# ══════════════════════════════════════════════════════════════════════════════

      bridge_domains:

        # ── BD-ACAS-MGMT (IPv6-only, no IPv4 predecessor) ───────────────────
        - name: BD-ACAS-MGMT
          vrf: VRF-EUR

        # ── BD-ACAS-SCANNERS ────────────────────────────────────────────────
        # From: BD-V0174 (APCG_ACAS), BD-V0474 (APCK_RETINA), BD-V0099
        - name: BD-ACAS-SCANNERS
          vrf: VRF-EUR
          subnets:
            - ip: 136.215.194.1/27
              public: true
              shared: false
            - ip: 136.215.66.1/27
              public: true
              shared: false

        # ── BD-AD ───────────────────────────────────────────────────────────
        # From: BD-V0172 (APCG_AD), BD-V0322, BD-V0222
        - name: BD-AD
          vrf: VRF-EUR
          subnets:
            - ip: 136.215.193.1/26
              public: true
              shared: false
            - ip: 155.155.136.1/26
              public: true
              shared: false
            - ip: 155.155.72.1/26
              public: true
              shared: false

        # ── BD-ADM-DCO ──────────────────────────────────────────────────────
        # From: BD-V0481 (DCOD_IDS)
        - name: BD-ADM-DCO
          vrf: VRF-EUR
          subnets:
            - ip: 155.155.230.97/28
              public: true
              shared: false

        # ── BD-ADFS (IPv6-only, no IPv4 predecessor) ────────────────────────
