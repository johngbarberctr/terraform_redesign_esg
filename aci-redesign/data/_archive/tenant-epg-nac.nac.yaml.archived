          vrf: VRF-EUR

        # ── BD-APP-SVR ──────────────────────────────────────────────────────
        # Absorbs 45 legacy BDs -- largest consolidation.
        # From: BD-V0572, V0372, V0272, V0455, V0528, V0419, V0266, V0520,
        #       V0125, V0265, V0267, V0521, V0142, V0542, V0472, V0616,
        #       V0219, V0524, V0576, V0210, V0310, V0531, V0582, V0299,
        #       V0373, V0470, V0475, V0570, V1595, V1596, and others.
        - name: BD-APP-SVR
          vrf: VRF-EUR
          subnets:
            # HIGH -- APCE_EUR_APPS_V572
            - ip: 155.155.236.65/26
              public: true
              shared: false
            # HIGH -- APCG_EUR_APPS
            - ip: 155.155.172.1/24
