# ============================================================================
# BRIDGE DOMAINS AND SUBNETS
# ============================================================================

# Bridge Domain: Infrastructure Management Services
resource "mso_schema_template_bd" "bd_infra_mgmt" {
  schema_id              = data.mso_schema.existing.id
  template_name          = "L2_Stretched"
  name                   = "BD-INFRA-MGMT"
  display_name           = "BD-INFRA-MGMT"
  vrf_name               = mso_schema_template_vrf.vrf_infra_mgmt.name
  vrf_schema_id          = data.mso_schema.existing.id
  vrf_template_name      = "UpgradeTemplate1"
  layer2_unknown_unicast = "proxy"
  layer2_stretch         = true
  
}

resource "mso_schema_template_bd_subnet" "bd_infra_mgmt_nac" {
  schema_id     = data.mso_schema.existing.id
  template_name = "L2_Stretched"
  bd_name       = mso_schema_template_bd.bd_infra_mgmt.name
  ip            = "fd00:10:10:15::1/64"
  scope         = "public"
  shared        = true
}

resource "mso_schema_template_bd_subnet" "bd_infra_mgmt_cfg" {
  schema_id     = data.mso_schema.existing.id
  template_name = "L2_Stretched"
  bd_name       = mso_schema_template_bd.bd_infra_mgmt.name
  ip            = "fd00:10:10:69::1/64"
  scope         = "public"
  shared        = true
}

resource "mso_schema_template_bd_subnet" "bd_infra_mgmt_gef" {
  schema_id     = data.mso_schema.existing.id
