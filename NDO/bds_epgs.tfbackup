# ============================================================================
# CONTRACTS AND FILTERS FOR vzAny
# Note: Contract and filter must be created together
# ============================================================================

# 1. Contract for VRF-INFRA-MGMT
resource "mso_schema_template_contract" "contract_vrf_infra_mgmt" {
  schema_id     = data.mso_schema.existing.id
  template_name = "UpgradeTemplate1"  # Changed from UpgradeTemplate1
  contract_name = "Any_VRF-INFRA-MGMT"
  display_name  = "Any_VRF-INFRA-MGMT"
  filter_type   = "bothWay"
  scope         = "context"
  
  filter_relationship {
    filter_schema_id     = data.mso_schema.existing.id
    filter_template_name = "UpgradeTemplate1"
    filter_name          = "Any"
    filter_type   = "bothWay"
  }
}

# 2. Contract for VRF-NET-SERVICES
