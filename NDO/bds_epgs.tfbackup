# Complete Terraform configuration for VRFs, BDs, EPGs, and Site Associations
# Save this as bds_epgs.tf

# Data sources for existing resources
data "mso_schema" "existing" {
  name = "AEDCE"
}

data "mso_site" "aedck" {
  name = "AEDCK"
}

data "mso_tenant" "eur" {
  name = "EUR"
}

# Test to see what templates Terraform can see
output "debug_schema_info" {
  value = {
    schema_id   = data.mso_schema.existing.id
    schema_name = data.mso_schema.existing.name
    templates   = data.mso_schema.existing.template
  }
}

# ============================================================================
# VRF DEFINITIONS
# Note: Template internal name is "UpgradeTemplate1" (display name: "VRF_Template")
# ============================================================================


# VRF: Infrastructure Management Services
resource "mso_schema_template_vrf" "vrf_infra_mgmt" {
  schema_id     = data.mso_schema.existing.id
  template      = "UpgradeTemplate1"
  name          = "VRF-INFRA-MGMT"
  display_name  = "VRF-INFRA-MGMT"
  layer3_multicast = false
  vzany         = true
}

# VRF: Network Services
resource "mso_schema_template_vrf" "vrf_net_services" {
  schema_id     = data.mso_schema.existing.id
  template      = "UpgradeTemplate1"
  name          = "VRF-NET-SERVICES"
  display_name  = "VRF-NET-SERVICES"
  layer3_multicast = false
  vzany         = true
}

# VRF: Voice and Communications
resource "mso_schema_template_vrf" "vrf_voice_comm" {
  schema_id     = data.mso_schema.existing.id
  template      = "UpgradeTemplate1"
  name          = "VRF-VOICE-COMM"
  display_name  = "VRF-VOICE-COMM"
  layer3_multicast = false
  vzany         = true
}

# VRF: Security Services
