# ============================================================================
# VRF vzAny CONTRACT RELATIONSHIPS
# Binds contracts to vzAny for each VRF (both provider and consumer)
# ============================================================================

# 1. VRF-INFRA-MGMT vzAny Contracts
resource "mso_schema_template_vrf_contract" "vrf_infra_mgmt_provider" {
  schema_id         = data.mso_schema.existing.id
  template_name     = "UpgradeTemplate1"
  vrf_name          = mso_schema_template_vrf.vrf_infra_mgmt.name
  relationship_type = "provider"
  contract_name     = mso_schema_template_contract.contract_vrf_infra_mgmt.contract_name
  
  depends_on = [
    mso_schema_template_contract.contract_vrf_infra_mgmt
  ]
}

resource "mso_schema_template_vrf_contract" "vrf_infra_mgmt_consumer" {
  schema_id         = data.mso_schema.existing.id
  template_name     = "UpgradeTemplate1"
  vrf_name          = mso_schema_template_vrf.vrf_infra_mgmt.name
  relationship_type = "consumer"
  contract_name     = mso_schema_template_contract.contract_vrf_infra_mgmt.contract_name
  
  depends_on = [
    mso_schema_template_contract.contract_vrf_infra_mgmt
  ]
}

