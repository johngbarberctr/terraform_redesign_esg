}

resource "mso_schema_site_anp_epg_static_port" "epg_vhost_mgmt_k_vpc_d2" {
  schema_id            = data.mso_schema.existing.id
  template_name        = "L2_Stretched"
  site_id              = data.mso_site.apic2.id
  anp_name             = mso_schema_template_anp.appprof_rcc_stretched.name
  epg_name             = mso_schema_template_anp_epg.epg_vhost_mgmt.name
  path_type            = "vpc"
  pod                  = "pod-1"
  leaf                 = "101-102"
  path                 = "VPC_D2A-B"
  vlan                 = 3102
  deployment_immediacy = "immediate"
  mode                 = "regular"

  depends_on = [mso_schema_site_anp_epg.epg_vhost_mgmt_site_k]
}

resource "mso_schema_site_anp_epg_static_port" "epg_vhost_mgmt_k_vpc_d3" {
  schema_id            = data.mso_schema.existing.id
  template_name        = "L2_Stretched"
  site_id              = data.mso_site.apic2.id
  anp_name             = mso_schema_template_anp.appprof_rcc_stretched.name
  epg_name             = mso_schema_template_anp_epg.epg_vhost_mgmt.name
  path_type            = "vpc"
  pod                  = "pod-1"
  leaf                 = "101-102"
  path                 = "VPC_D3A-B"
  vlan                 = 3102
  deployment_immediacy = "immediate"
  mode                 = "regular"

  depends_on = [mso_schema_site_anp_epg.epg_vhost_mgmt_site_k]
}

# ============================================================================
# NOTE: SVI INTERFACE CONFIGURATION
# ============================================================================
# The MSO Terraform provider does not support detailed L3Out interface 
# configuration (SVI, node profiles, interface profiles, IPs) directly.
#
# After deploying via Terraform, configure the following in NDO GUI or APIC:
#
# Site G (AEDCG) - L3Out-G_VHOST-MGMT:
#   - Node Profile: Add leaf nodes (e.g., 101, 102)
#   - Interface Profile: SVI on VLAN 3500
#   - Interface IPs (placeholder - modify as needed):
#     - Port 1: fd00:66:1::1/64
#     - Port 2: fd00:66:1::2/64
#
# Site K (AEDCK) - L3Out-K_VHOST-MGMT:
#   - Node Profile: Add leaf nodes (e.g., 101, 102)
#   - Interface Profile: SVI on VLAN 3500
#   - Interface IPs (placeholder - modify as needed):
#     - Port 1: fd00:66:2::1/64
#     - Port 2: fd00:66:2::2/64
#
# ============================================================================
