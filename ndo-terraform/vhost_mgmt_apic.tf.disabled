#   addr                      = "fd00:66:2::20/64"  # Side A IP (different from primary)
#   ipv6_dad                  = "enabled"
# }

# ============================================================================
# OUTPUTS
# ============================================================================

output "site_g_l3out_node_profile" {
  description = "Site G L3Out Node Profile DN"
  value       = aci_logical_node_profile.l3out-G_VHOST-MGMT_node_profile.id
}

output "site_g_l3out_interface_profile" {
  description = "Site G L3Out Interface Profile DN"
  value       = aci_logical_interface_profile.l3out-G_VHOST-MGMT_int_profile.id
}

output "site_k_l3out_node_profile" {
  description = "Site K L3Out Node Profile DN"
  value       = aci_logical_node_profile.l3out-K_VHOST-MGMT_node_profile.id
}

output "site_k_l3out_interface_profile" {
  description = "Site K L3Out Interface Profile DN"
  value       = aci_logical_interface_profile.l3out-K_VHOST-MGMT_int_profile.id
}
*/

# ============================================================================
# USAGE NOTES
# ============================================================================
#
# STEP 1: Deploy NDO resources first (with APIC resources commented out above)
#    terraform apply
#
# STEP 2: Wait for NDO to push L3Outs to APIC (check in APIC GUI)
#
# STEP 3: Uncomment the APIC resources above:
#    - Remove /* on line 94
#    - Remove */ on line 287
#
# STEP 4: Update placeholder values:
#    - APIC URLs in terraform.tfvars
#    - VLAN (l3out_vlan)
#    - IPv6 addresses
#    - Router IDs
#    - VPC names if different
#
# STEP 5: Apply APIC configuration:
#    terraform apply
#
# ============================================================================
