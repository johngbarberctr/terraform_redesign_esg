#   ipv6_dad                  = "enabled"
# }

# SVI Path Attachment - VPC_D2A-B (Site K)
resource "aci_l3out_path_attachment" "l3out-K_VHOST-MGMT_svi_vpc2" {
  provider                     = aci.apic_k
  logical_interface_profile_dn = aci_logical_interface_profile.l3out-K_VHOST-MGMT_int_profile.id
  target_dn                    = "topology/pod-1/protpaths-101-102/pathep-[VPC_D2A-B]"
  if_inst_t                    = "ext-svi"
