# ============================================================================
# CONSOLIDATED BD #3: EUR-AIV-UC-Services
# ============================================================================
# Consolidates 6 AIV BDs with UC/voice subnets + L3Out-G_AIV

resource "mso_schema_template_bd" "bd_eur_aiv_uc_services" {
  schema_id              = mso_schema.eur_schema.id
  template_name          = "EUR-AIV-Template"
  name                   = "BD-EUR-AIV-UC-Services"
  display_name           = "BD-EUR-AIV-UC-Services"
  description            = "Consolidated EUR-AIV UC Services (6 BDs)"
  vrf_name               = mso_schema_template_vrf.vrf_eur_aiv.name
  vrf_schema_id          = mso_schema.eur_schema.id
  vrf_template_name      = "SharedTemplate"
  layer2_unknown_unicast = "flood"
  layer2_stretch         = true
  unicast_routing        = true
  arp_flooding           = true
  intersite_bum_traffic  = true
  optimize_wan_bandwidth = false

  # L3Out association: L3Out-G_AIV (associated via mso_schema_template_bd_l3out if needed)
}

