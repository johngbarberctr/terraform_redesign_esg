# ============================================================================
# EUR CONSOLIDATED TERRAFORM CONFIGURATION - COMPLETE VERSION
# ============================================================================
# Tenant: EUR-Consolidated
# Schema: EUR-Consolidated-Schema
# Consolidates 216 BDs into 7 VRF-based logical groups
# All IPv4 subnets from existing BD-Vxxxx BDs preserved
# Sites: AEDCG and AEDCK
# ============================================================================

# Data sources (mso_site.aedcg, mso_site.aedck) and required_providers
# are defined in bds_epgs.tf and main.tf respectively.

# ============================================================================
# TENANT
# ============================================================================

resource "mso_tenant" "eur_consolidated" {
  name         = "EUR-Consolidated"
  display_name = "EUR-Consolidated"
  description  = "Consolidated EUR Tenant - 216 BDs to 7 logical groups"

  site_associations {
    site_id = data.mso_site.aedcg.id
  }
  site_associations {
    site_id = data.mso_site.aedck.id
  }
}

# ============================================================================
# SCHEMA
# ============================================================================

resource "mso_schema" "eur_schema" {
  name = "EUR-Consolidated-Schema"

  template {
    name         = "SharedTemplate"
    display_name = "SharedTemplate"
    tenant_id    = mso_tenant.eur_consolidated.id
  }
  template {
    name         = "EUR-E-Template"
    display_name = "EUR-E-Template"
    tenant_id    = mso_tenant.eur_consolidated.id
  }
  template {
    name         = "EUR-AIS-Template"
    display_name = "EUR-AIS-Template"
    tenant_id    = mso_tenant.eur_consolidated.id
  }
  template {
    name         = "EUR-AIV-Template"
    display_name = "EUR-AIV-Template"
    tenant_id    = mso_tenant.eur_consolidated.id
  }
  template {
    name         = "EUR-AIZ-Template"
    display_name = "EUR-AIZ-Template"
    tenant_id    = mso_tenant.eur_consolidated.id
  }
  template {
    name         = "EUR-AIM-Template"
    display_name = "EUR-AIM-Template"
    tenant_id    = mso_tenant.eur_consolidated.id
  }
  template {
    name         = "EUR-AIP-Template"
    display_name = "EUR-AIP-Template"
    tenant_id    = mso_tenant.eur_consolidated.id
  }
  template {
    name         = "EUR-AOV-Template"
    display_name = "EUR-AOV-Template"
    tenant_id    = mso_tenant.eur_consolidated.id
  }
  template {
    name         = "VRF_Template"
    display_name = "VRF_Template"
    tenant_id    = mso_tenant.eur_consolidated.id
  }
}

