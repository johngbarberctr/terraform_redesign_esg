# OUTPUTS
# ============================================================================

output "consolidation_summary" {
  value = {
    tenant             = mso_tenant.eur_consolidated.name
    schema             = mso_schema.eur_schema.name
    original_bd_count  = 216
    consolidated_count = 7
    consolidation_ratio = "216:7 (97% reduction)"
    
    consolidated_bds = {
      "BD-EUR-E-L2-Services"    = "79 L2-only BDs (no subnets)"
      "BD-EUR-AIS-Services"     = "66 BDs with 53 subnets"
      "BD-EUR-AIV-UC-Services"  = "6 BDs with UC subnets"
      "BD-EUR-AIZ-ITSM-Services"= "5 BDs with ITSM subnets"
      "BD-EUR-AIM-InbandMGT"    = "8 BDs with MGT subnets"
      "BD-EUR-AIP-Services"     = "54 BDs with services subnets"
      "BD-EUR-AOV-UC-DMZ"       = "1 BD with DMZ subnet"
    }
    
    l3outs = [
      "L3Out-G_AIS",
      "L3Out-G_AIV", 
      "L3Out-G_AIZ",
      "L3Out-G_AIM",
      "L3Out-G_AIP",
      "L3Out-G_EUR-AOV-UC-DMZ"
    ]
    
    sites = ["AEDCG", "AEDCK"]
  }
}
