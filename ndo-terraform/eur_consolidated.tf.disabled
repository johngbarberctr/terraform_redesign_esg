  schema_id         = mso_schema.eur_schema.id
  template_name     = "EUR-AIV-Template"
  anp_name          = mso_schema_template_anp.appprof_eur_aiv.name
  name              = "EPG-EUR-AIV-UC-Services"
  display_name      = "EPG-EUR-AIV-UC-Services"
