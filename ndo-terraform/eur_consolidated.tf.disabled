# ============================================================================
# CONSOLIDATED BD #1: EUR-E-L2-Services
# ============================================================================
# Pure L2 BDs (79 total, all without subnets)
# Original BDs: BD-V0009, BD-V0010, BD-V0021, BD-V0022, BD-V0033, BD-V0091, 
# BD-V0092, BD-V0099, BD-V0106, BD-V0108, BD-V0110, BD-V0162, BD-V0164,
# BD-V0194, BD-V0229, BD-V0230, BD-V0231, BD-V0232, BD-V0233, BD-V0234,
# BD-V0268, BD-V0292, BD-V0311, BD-V0312, BD-V0313, BD-V0314, BD-V0410,
# BD-V0454, BD-V0510, BD-V0520, BD-V0521, BD-V0522, BD-V0528, BD-V0535,
# BD-V0536, BD-V0537, BD-V0538, BD-V0540, BD-V0542, BD-V0543, BD-V0544,
# BD-V0545, BD-V0546, BD-V0548, BD-V0550, BD-V0554, BD-V0560, BD-V0564,
# BD-V0566, BD-V0568, BD-V0570, BD-V0572, BD-V0574, BD-V0576, BD-V0578,
# BD-V0710, BD-V0712, BD-V0714, BD-V0716, BD-V0718, BD-V0720, BD-V0722,
# BD-V0724, BD-V0726, BD-V0728, BD-V0730, BD-V0732, BD-V0734, BD-V0736,
# BD-V0738, BD-V0740, BD-V1000, BD-V1002, BD-V1010, BD-V1012, BD-V1500,
# BD-V1502, BD-V1504, BD-V2000

resource "mso_schema_template_bd" "bd_eur_e_l2_services" {
  schema_id              = mso_schema.eur_schema.id
  template_name          = "EUR-E-Template"
  name                   = "BD-EUR-E-L2-Services"
  display_name           = "BD-EUR-E-L2-Services"
  description            = "Consolidated EUR-E L2 Services (79 L2-only BDs)"
  vrf_name               = mso_schema_template_vrf.vrf_eur_e.name
  vrf_schema_id          = mso_schema.eur_schema.id
  vrf_template_name      = "SharedTemplate"
  layer2_unknown_unicast = "flood"
  layer2_stretch         = true
  unicast_routing        = false
  arp_flooding           = true
  intersite_bum_traffic  = true
  optimize_wan_bandwidth = false
}

resource "mso_schema_template_anp_epg" "epg_eur_e_l2_services" {
  schema_id         = mso_schema.eur_schema.id
  template_name     = "EUR-E-Template"
  anp_name          = mso_schema_template_anp.appprof_eur_e.name
  name              = "EPG-EUR-E-L2-Services"
  display_name      = "EPG-EUR-E-L2-Services"
  bd_name           = mso_schema_template_bd.bd_eur_e_l2_services.name
  bd_schema_id      = mso_schema.eur_schema.id
  bd_template_name  = "EUR-E-Template"
  vrf_name          = mso_schema_template_vrf.vrf_eur_e.name
  vrf_schema_id     = mso_schema.eur_schema.id
  vrf_template_name = "SharedTemplate"
  proxy_arp         = false
}

# ============================================================================
# CONSOLIDATED BD #2: EUR-AIS-Services
# ============================================================================
# Consolidates 66 AIS BDs with 53 subnets + L3Out-G_AIS

resource "mso_schema_template_bd" "bd_eur_ais_services" {
  schema_id              = mso_schema.eur_schema.id
  template_name          = "EUR-AIS-Template"
  name                   = "BD-EUR-AIS-Services"
  display_name           = "BD-EUR-AIS-Services"
  description            = "Consolidated EUR-AIS Services (66 BDs, 53 subnets)"
  vrf_name               = mso_schema_template_vrf.vrf_eur_ais.name
  vrf_schema_id          = mso_schema.eur_schema.id
  vrf_template_name      = "SharedTemplate"
  layer2_unknown_unicast = "flood"
  layer2_stretch         = true
  unicast_routing        = true
  arp_flooding           = true
  intersite_bum_traffic  = true
  optimize_wan_bandwidth = false

  # L3Out association: L3Out-G_AIS (associated via mso_schema_template_bd_l3out if needed)
}

resource "mso_schema_template_anp_epg" "epg_eur_ais_services" {
  schema_id         = mso_schema.eur_schema.id
  template_name     = "EUR-AIS-Template"
  anp_name          = mso_schema_template_anp.appprof_eur_ais.name
  name              = "EPG-EUR-AIS-Services"
  display_name      = "EPG-EUR-AIS-Services"
  bd_name           = mso_schema_template_bd.bd_eur_ais_services.name
  bd_schema_id      = mso_schema.eur_schema.id
  bd_template_name  = "EUR-AIS-Template"
  vrf_name          = mso_schema_template_vrf.vrf_eur_ais.name
  vrf_schema_id     = mso_schema.eur_schema.id
  vrf_template_name = "SharedTemplate"
  proxy_arp         = false
}

