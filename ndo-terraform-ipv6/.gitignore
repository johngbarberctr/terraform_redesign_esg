# Terraform state and runtime
*.tfstate
*.tfstate.*
*.tfvars
.terraform/
.terraform.lock.hcl
*.tfplan
crash.log

# Disabled/offline/backup Terraform configs
*.disabled
*.offline
*.backup

# Local-only Terraform overrides — used to swap the http backend for a local
# backend during interactive lab work on a laptop. Must never be committed:
# CI must keep using the http backend driven by TF_HTTP_* env vars.
*_override.tf
*_override.tf.json

# Directories not needed in repo
test-ndo/
tf-modules/

# Python scripts and artifacts
*.py
__pycache__/
*.py[cod]
venv/
env/

# Data and binary files
*.json
*.tar.gz
*.zip
*.xlsx
*.csv

# Logs
*.log
*.out

